{
  "id": "prologue_intro",
  "durationMs": 6000,
  "tracks": [
    {
      "id": "fx.fadein",
      "kind": "camera",
      "channel": "fx",
      "clips": [
        { "type": "cameraEffect", "atMs": 0, "effect": "fade", "durationMs": 1200, "color": "black", "from": 1, "to": 0 }
      ]
    },
    {
      "id": "fx.letterbox",
      "kind": "camera",
      "channel": "fx",
      "clips": [
        { "type": "cameraEffect", "atMs": 0, "effect": "letterbox", "durationMs": 5500, "height": 72, "speed": 240 }
      ]
    },
    {
      "id": "camera.scripted",
      "kind": "camera",
      "binding": { "cameraId": "scripted" },
      "channel": "blend",
      "clips": [
        { "type": "cameraBlend", "startMs": 0, "durationMs": 0, "to": "scripted" },
        { "type": "setCameraFrame", "atMs": 0, "center": [-0, 0, 0], "height": 4.5, "orthoWidth": 8 },
        { "type": "setCameraFollow", "atMs": 200, "actorId": "companion", "offsetX": 0, "offsetY": 0, "offsetZ": 0, "lerp": 0.12, "height": 1.6, "orthoWidth": 20 }
      ]
    },
    {
      "id": "hero.walk",
      "kind": "actor",
      "binding": { "actorId": "hero" },
      "channel": "movement",
      "clips": [
        { "type": "inputLock", "atMs": 0, "locked": true },
        { "type": "command", "atMs": 200, "command": "walk" },
        { "type": "moveActorTo", "startMs": 200, "durationMs": 3000, "x": -18, "y": 1, "speed": 1.4 },
        { "type": "inputLock", "atMs": 5500, "locked": false }
      ]
    },
    {
      "id": "companion.walk",
      "kind": "actor",
      "binding": { "actorId": "companion" },
      "channel": "movement",
      "clips": [
        { "type": "command", "atMs": 600, "command": "walk" },
        { "type": "moveActorTo", "startMs": 600, "durationMs": 3000, "x": -18, "y": 0, "speed": 1.4 },
        { "type": "callback", "atMs": 3600, "fn": "enterCompanionIdle" }
      ]
    },
    {
      "id": "camera.back",
      "kind": "camera",
      "binding": { "cameraId": "explore" },
      "channel": "blend",
      "clips": [
        { "type": "cameraBlend", "startMs": 5000, "durationMs": 1000, "to": "explore" }
      ]
    }
  ]
